# Copy to .env for local dev. In production these come from Cloud Run / Secret Manager.

# Neon Postgres connection string (use the POOLED connection string for the server).
DATABASE_URL=postgres://user:password@ep-xxx-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require

# Google OAuth client (GCP console > APIs & Services > Credentials).
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxxxxx

# Long random string used to sign session JWTs. Generate with: openssl rand -base64 48
SESSION_SECRET=change-me

# Anthropic API key for the AI chat tutor (platform.claude.com > API keys).
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# The two Google accounts allowed to sign in (comma-separated, lowercase).
ALLOWED_EMAILS=you@gmail.com,her@gmail.com

# Public origin of the app. Dev: http://localhost:5173  Prod: https://language.levanto.dev
# The OAuth redirect URI is ${BASE_URL}/api/auth/callback
BASE_URL=http://localhost:5173

# --- Web Push (daily training reminder) --- all optional; leave unset to disable.
# Generate the VAPID pair once with:  npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact URI embedded in the VAPID JWT (mailto: or https:). Defaults to the owner.
VAPID_SUBJECT=mailto:you@example.com
# Shared secret the reminders cron (GitHub Actions) presents to /api/push/send-reminders.
# Generate with: openssl rand -hex 32
CRON_SECRET=
